# Client-side AI provider keys for the current Vite/browser architecture.
# These keys are exposed to the browser bundle. Use only for demos/portfolio builds;
# production deployments should proxy provider requests through a server.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"
VITE_OPENAI_API_KEY="MY_OPENAI_API_KEY"
VITE_CLAUDE_API_KEY="MY_CLAUDE_API_KEY"

# Backward-compatible Gemini key used by earlier builds.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional model overrides.
VITE_GEMINI_MODEL="gemini-3-flash-preview"
VITE_OPENAI_MODEL="gpt-4o-mini"
VITE_CLAUDE_MODEL="claude-3-5-haiku-latest"

# Optional provider defaults: gemini, openai, or claude.
VITE_AI_PROVIDER="gemini"
VITE_FALLBACK_AI_PROVIDER="gemini"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
